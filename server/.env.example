# Vorlage — echte Werte gehören in server/.env (gitignored, NIE einchecken).

# Supabase: Dashboard -> Settings -> Database -> Connection string
# Empfohlen: der Pooler-String ("Connection pooling" / Supavisor).
DATABASE_URL=postgresql://BENUTZER:PASSWORT@HOST:PORT/postgres

# Supabase: Dashboard -> Settings -> API
# Wird für die JWT-Prüfung der App-Tokens gebraucht (kommt im Auth-Schritt).
SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
SUPABASE_JWT_SECRET=

# Betrieb
PORT=4000
NODE_ENV=development
# Kommagetrennte erlaubte Browser-Origins (in Produktion Pflicht).
CORS_ORIGINS=
# Demo-Daten nur bewusst in Produktion anlegen:
# ZAMMA_SEED=1
